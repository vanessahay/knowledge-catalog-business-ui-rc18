# Example environment variables template (DO NOT STORE REAL SECRETS HERE)
# Copy this file to .env locally for development.

VITE_API_URL=/api
VITE_API_VERSION=v1
VITE_ADMIN_EMAIL=your-admin-email@example.com
VITE_GOOGLE_PROJECT_ID=your-gcp-project-id
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
VITE_GOOGLE_REDIRECT_URI=/auth/google/callback

# Backend runtime secrets (stored in GCP Secret Manager for Cloud Run production)
# GOOGLE_CLIENT_SECRET=your-google-client-secret
